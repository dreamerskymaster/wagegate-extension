{
  "manifest_version": 3,
  "name": "WageGate H1B Prevailing Wage Search",
  "version": "1.1.0",
  "description": "Highlight any job title on any website and check its H1B prevailing wage level.",
  "permissions": ["contextMenus"],
  "host_permissions": [
    "https://wagegate.onrender.com/*",
    "http://localhost:3000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open WageGate"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
